# Shopify Data Admin 环境变量示例
# 复制为 .env 后，将示例值替换为真实店铺域名和 Admin API access token。
# 店铺只有同时配置 SHOPIFY_STORE_DOMAIN 与 SHOPIFY_ADMIN_ACCESS_TOKEN 后才会出现在工具下拉列表中。
# Admin Token 权限需与所用工具一致：图片上传 / 图片同步需 read_files、write_files；跨店铺产品同步另需 read_products、write_products。
# 前台选择项 value 使用店铺域名（storeDomain），服务端再按映射读取对应 env 变量。

# JP 站点
JP_SHOPIFY_STORE_DOMAIN=valerion-jp-demo.myshopify.com
JP_SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_jp_example_admin_access_token_00000000000000000000000000000000

# US 站点
US_SHOPIFY_STORE_DOMAIN=valerion-us-demo.myshopify.com
US_SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_us_example_admin_access_token_00000000000000000000000000000000

# EU 站点
